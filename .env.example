# ─── PUBLIC (bundled into browser via Vite) ───────────────────────────────────
# These are intentionally client-side. Security relies on Supabase RLS, not
# key secrecy. Never add VITE_ prefix to server-side-only secrets.

VITE_SUPABASE_URL=https://<project-id>.supabase.co
VITE_SUPABASE_PROJECT_ID=<project-id>

# Supabase anon key — public by design, protected by RLS policies
VITE_SUPABASE_ANON_KEY=<supabase-anon-jwt>
VITE_SUPABASE_PUBLISHABLE_KEY=<supabase-anon-jwt>   # legacy alias, same value

# Spotify OAuth client ID — public, used in PKCE flow
VITE_SPOTIFY_CLIENT_ID=<spotify-client-id>

# Optional: override the OAuth redirect URI (defaults to current origin + /spotify-callback)
# VITE_SPOTIFY_REDIRECT_URI=https://your-app.vercel.app/spotify-callback

# ─── PRIVATE (server-side only — Edge Functions / Supabase secrets) ───────────
# Do NOT prefix these with VITE_ — they must never appear in the browser bundle.
#
# Set these in: Supabase Dashboard → Project Settings → Edge Functions → Secrets
#               Vercel Dashboard → Project → Settings → Environment Variables (mark Sensitive)
#
# SUPABASE_SERVICE_ROLE_KEY=<service-role-jwt>
# SPOTIFY_CLIENT_SECRET=<spotify-client-secret>
# DISCOGS_CONSUMER_KEY=<discogs-consumer-key>
# DISCOGS_CONSUMER_SECRET=<discogs-consumer-secret>
# ANTHROPIC_API_KEY=<anthropic-api-key>
